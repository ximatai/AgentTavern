{
  "name": "agent-tavern",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @agent-tavern/server --filter @agent-tavern/ui dev",
    "dev:server": "pnpm --filter @agent-tavern/server dev",
    "dev:ui": "pnpm --filter @agent-tavern/ui dev",
    "dev:bridge": "pnpm --filter @agent-tavern/bridge dev",
    "build": "pnpm -r build",
    "test:server": "pnpm --filter @agent-tavern/server test",
    "test:bridge": "pnpm --filter @agent-tavern/bridge test",
    "test:e2e": "pnpm exec playwright test",
    "typecheck": "pnpm -r typecheck",
    "skill:install": "python3 tools/install-skill.py"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
