{
  "name": "agent-tavern",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @agent-tavern/server --filter @agent-tavern/web dev",
    "dev:server": "pnpm --filter @agent-tavern/server dev",
    "dev:web": "pnpm --filter @agent-tavern/web dev",
    "dev:bridge": "pnpm --filter @agent-tavern/bridge dev",
    "build": "pnpm -r build",
    "test:server": "pnpm --filter @agent-tavern/server test",
    "test:bridge": "pnpm --filter @agent-tavern/bridge test",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
